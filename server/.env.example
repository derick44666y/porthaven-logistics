# PostgreSQL connection string (Neon)
DATABASE_URL="postgresql://user:password@ep-example-123456.us-east-2.aws.neon.tech/porthaven?sslmode=require"

# JWT secret (generate a random string) — REQUIRED in production
JWT_SECRET="your-random-jwt-secret-here"

# One-time admin seed credentials. Use a strong unique password.
ADMIN_EMAIL="admin@example.com"
ADMIN_PASSWORD="replace-with-a-strong-unique-password"

# Allowed frontend origins (comma-separated). Production domain + Vercel + local
FRONTEND_URL="https://www.porthavenlogistic.com,https://porthaven-logistics-five.vercel.app,http://localhost:8443"

# Optional: public site URL used in email tracking / login links (defaults to first FRONTEND_URL)
SITE_URL="https://www.porthavenlogistic.com"

# Resend email notifications (required for status, welcome, and contact emails)
RESEND_API_KEY="re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx"
NOTIFY_FROM_EMAIL="updates@porthavenlogistic.com"
ADMIN_NOTIFY_EMAIL="info@example.com"

# Server port
PORT=3001

# Invoice issuer details (shown on generated PDF invoices)
COMPANY_NAME="PortHaven Logistics"
COMPANY_ADDRESS="123 Harbour Plaza, Suite 400, Los Angeles, CA 90012, USA"
COMPANY_EMAIL="billing@porthavenlogistic.com"
COMPANY_PHONE="+1 (800) 555-0142"
COMPANY_TAX_ID="US-GBL-88420193"
COMPANY_WEBSITE="https://www.porthavenlogistic.com"

# Invoice tax rate as a percentage, e.g. 0, 7.5, 20. Applied to the shipment amount.
INVOICE_TAX_RATE=0
